<%- include('partials/head', { pageTitle, bodyClass: 'site-body' }) %>
<%- include('partials/site-header') %>

<section class="hero hero-inner hero-allowlist">
  <div class="shell hero-shell">
    <div class="hero-copy compact">
      <span class="eyebrow">Allowlist integrada</span>
      <h1>Liberar allowlist</h1>
      <p>Consulte o passaporte na base vRP, confirme os dados e libere a entrada de forma segura e organizada.</p>
    </div>
  </div>
</section>

<%- include('partials/flash', { flash }) %>

<section class="section">
  <div class="shell two-column">
    <article class="panel">
      <h2>Consulta de passaporte</h2>
      <p class="muted">Informe os dados do personagem e faça a conferência antes da liberação.</p>

      <form class="stack-form" action="/allowlist/check" method="post">
        <label>
          <span>Passaporte / ID</span>
          <input type="text" name="passport" value="<%= formData.passport || '' %>" required inputmode="numeric">
        </label>
        <label>
          <span>Nome</span>
          <input type="text" name="fullName" value="<%= formData.fullName || '' %>" required>
        </label>
        <div class="field-row">
          <label>
            <span>Idade</span>
            <input type="text" name="age" value="<%= formData.age || '' %>" required>
          </label>
          <label>
            <span>Recrutador</span>
            <input type="text" name="recruiter" value="<%= formData.recruiter || '' %>">
          </label>
        </div>
        <div class="field-row">
          <label>
            <span>Discord</span>
            <input type="text" name="discordTag" value="<%= formData.discordTag || '' %>" placeholder="usuario#0001">
          </label>
          <label>
            <span>ID do Discord</span>
            <input type="text" name="discordId" value="<%= formData.discordId || '' %>" placeholder="1234567890">
          </label>
        </div>
        <label>
          <span>Por que quer entrar na cidade?</span>
          <textarea name="reason" rows="5" required><%= formData.reason || '' %></textarea>
        </label>
        <button class="button" type="submit">Consultar allowlist</button>
      </form>
    </article>

    <article class="panel">
      <h2>Resultado</h2>
      <% if (!databaseReady) { %>
        <div class="empty-state">
          <h3>Banco ainda não conectado</h3>
          <p>Configure o MySQL da base vRP para habilitar a consulta e a liberação automática.</p>
        </div>
      <% } else if (!result) { %>
        <div class="empty-state">
          <h3>Pronto para consultar</h3>
          <p>Depois da consulta, esta área mostra o status do passaporte, solicitações anteriores e a ação de liberação.</p>
        </div>
      <% } else if (!result.player) { %>
        <div class="empty-state">
          <h3>Passaporte não localizado</h3>
          <p>O personagem ainda não existe na base vRP. Entre na cidade primeiro para gerar o cadastro.</p>
        </div>
      <% } else { %>
        <div class="status-card">
          <span class="tag <%= result.alreadyReleased ? 'tag-success' : result.canRelease ? 'tag-highlight' : '' %>">
            <%= result.alreadyReleased ? 'Liberado' : result.canRelease ? 'Pronto para liberar' : 'Em análise' %>
          </span>
          <h3><%= result.player.first_name || 'Sem nome' %> <%= result.player.last_name || '' %></h3>
          <p>Passaporte <strong>#<%= result.passport %></strong></p>
          <div class="detail-list">
            <div><span>Telefone</span><strong><%= result.player.phone || 'N/D' %></strong></div>
            <div><span>Registro</span><strong><%= result.player.registration || 'N/D' %></strong></div>
            <div><span>Último login</span><strong><%= result.player.last_login ? formatDateTime(result.player.last_login) : 'N/D' %></strong></div>
          </div>
        </div>

        <% if (result.latestRequest) { %>
          <div class="timeline-box">
            <strong>Última solicitação</strong>
            <p>Status: <%= result.latestRequest.status %></p>
            <p>Criada em: <%= formatDateTime(result.latestRequest.created_at) %></p>
          </div>
        <% } %>

        <% if (result.alreadyReleased) { %>
          <div class="cta-stack">
            <a class="button button-block" href="/conectar">Conectar na cidade</a>
          </div>
        <% } else if (result.canRelease) { %>
          <form class="stack-form" action="/allowlist/release" method="post">
            <input type="hidden" name="passport" value="<%= formData.passport || result.passport %>">
            <input type="hidden" name="fullName" value="<%= formData.fullName || '' %>">
            <input type="hidden" name="age" value="<%= formData.age || '' %>">
            <input type="hidden" name="recruiter" value="<%= formData.recruiter || '' %>">
            <input type="hidden" name="discordTag" value="<%= formData.discordTag || '' %>">
            <input type="hidden" name="discordId" value="<%= formData.discordId || '' %>">
            <input type="hidden" name="reason" value="<%= formData.reason || '' %>">
            <button class="button button-block" type="submit">Liberar allowlist agora</button>
          </form>
        <% } %>
      <% } %>
    </article>
  </div>
</section>

<%- include('partials/site-footer') %>
