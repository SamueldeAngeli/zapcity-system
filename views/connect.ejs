<%- include('partials/head', { pageTitle, bodyClass: 'site-body' }) %>
<%- include('partials/site-header') %>

<section class="hero hero-inner hero-connect">
  <div class="shell hero-shell">
    <div class="hero-copy compact">
      <span class="eyebrow">Conexão</span>
      <h1>Entrar na Zap City</h1>
      <p>Com a allowlist liberada, basta conectar usando o link direto do FiveM ou o comando manual abaixo.</p>
      <div class="hero-actions">
        <a class="button" href="<%= fivem.connectEndpoint %>">Abrir FiveM</a>
        <button class="button button-secondary" type="button" data-copy-value="<%= fivem.connectCommand %>">Copiar comando</button>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="shell two-column">
    <article class="panel">
      <h2>Link direto</h2>
      <p><code><%= fivem.connectEndpoint %></code></p>
      <a class="button button-block" href="<%= fivem.connectEndpoint %>">Conectar agora</a>
    </article>

    <article class="panel">
      <h2>Comando manual</h2>
      <p>Abra o console do FiveM e use:</p>
      <div class="code-box"><code><%= fivem.connectCommand %></code></div>
      <button class="button button-secondary button-block" type="button" data-copy-value="<%= fivem.connectCommand %>">Copiar comando</button>
    </article>
  </div>
</section>

<%- include('partials/site-footer') %>
