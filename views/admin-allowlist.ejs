<%- include('partials/head', { pageTitle, bodyClass: 'admin-body' }) %>
<%- include('partials/admin-nav') %>
<%- include('partials/flash', { flash }) %>

<main class="admin-main">
  <section class="section">
    <div class="shell table-shell">
      <h1>Solicitações de allowlist</h1>
      <table class="data-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Passaporte</th>
            <th>Nome</th>
            <th>Status</th>
            <th>Criada em</th>
            <th>Revisão</th>
          </tr>
        </thead>
        <tbody>
          <% requests.forEach((request) => { %>
            <tr>
              <td>#<%= request.id %></td>
              <td><%= request.passport %></td>
              <td><%= request.full_name %></td>
              <td><%= request.status %></td>
              <td><%= formatDateTime(request.created_at) %></td>
              <td>
                <form class="review-form" action="/admin/allowlist/<%= request.id %>/review" method="post">
                  <select name="status">
                    <option value="approved">approved</option>
                    <option value="rejected">rejected</option>
                    <option value="needs_review">needs_review</option>
                  </select>
                  <input type="text" name="notes" placeholder="Observação">
                  <button class="button button-small" type="submit">Aplicar</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

</body>
</html>
