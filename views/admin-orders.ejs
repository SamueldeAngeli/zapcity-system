<%- include('partials/head', { pageTitle, bodyClass: 'admin-body' }) %>
<%- include('partials/admin-nav') %>
<%- include('partials/flash', { flash }) %>

<main class="admin-main">
  <section class="section">
    <div class="shell table-shell">
      <h1>Pedidos da loja</h1>
      <table class="data-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Produto</th>
            <th>Categoria</th>
            <th>Passaporte</th>
            <th>Status</th>
            <th>Ação</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach((order) => { %>
            <tr>
              <td>#<%= order.id %></td>
              <td><%= order.product_name %></td>
              <td><%= order.category %></td>
              <td><%= order.passport %></td>
              <td><%= order.status %></td>
              <td>
                <form class="inline-control" action="/admin/pedidos/<%= order.id %>/status" method="post">
                  <select name="status">
                    <option value="pendente" <%= order.status === 'pendente' ? 'selected' : '' %>>pendente</option>
                    <option value="pago" <%= order.status === 'pago' ? 'selected' : '' %>>pago</option>
                    <option value="entregue" <%= order.status === 'entregue' ? 'selected' : '' %>>entregue</option>
                    <option value="cancelado" <%= order.status === 'cancelado' ? 'selected' : '' %>>cancelado</option>
                  </select>
                  <button class="button button-small" type="submit">Salvar</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

</body>
</html>
