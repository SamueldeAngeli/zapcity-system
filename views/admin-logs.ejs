<%- include('partials/head', { pageTitle, bodyClass: 'admin-body' }) %>
<%- include('partials/admin-nav') %>
<%- include('partials/flash', { flash }) %>

<main class="admin-main">
  <section class="section">
    <div class="shell table-shell">
      <h1>Logs gerais</h1>
      <table class="data-table">
        <thead>
          <tr>
            <th>Quando</th>
            <th>Categoria</th>
            <th>Ação</th>
            <th>Passaporte</th>
            <th>Mensagem</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach((item) => { %>
            <tr>
              <td><%= formatDateTime(item.created_at) %></td>
              <td><%= item.category %></td>
              <td><%= item.action %></td>
              <td><%= item.passport || '-' %></td>
              <td><%= item.message %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

</body>
</html>
