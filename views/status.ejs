<%- include('partials/head', { pageTitle, bodyClass: 'site-body' }) %>
<%- include('partials/site-header') %>

<section class="hero hero-inner hero-status">
  <div class="shell hero-shell">
    <div class="hero-copy compact">
      <span class="eyebrow">Monitoramento</span>
      <h1>Status da cidade</h1>
      <p>Visão rápida do endpoint configurado, quantidade de players e resposta do servidor.</p>
    </div>
  </div>
</section>

<%- include('partials/flash', { flash }) %>

<section class="section">
  <div class="shell info-grid">
    <article class="feature-card">
      <h3>Status</h3>
      <p class="<%= statusData.online ? 'text-success' : 'text-danger' %>"><%= statusData.online ? 'ONLINE' : 'OFFLINE' %></p>
    </article>
    <article class="feature-card">
      <h3>Players online</h3>
      <p><strong><%= statusData.playerCount %></strong></p>
    </article>
    <article class="feature-card">
      <h3>Slots</h3>
      <p><strong><%= statusData.maxClients || 'N/D' %></strong></p>
    </article>
  </div>
</section>

<section class="section section-dark">
  <div class="shell">
    <div class="split-band">
      <div>
        <h2>Endpoint monitorado</h2>
        <p><code><%= statusData.endpoint %></code></p>
      </div>
      <div class="cta-stack">
        <a class="button" href="/conectar">Ir para conexão</a>
      </div>
    </div>

    <% if (statusData.players && statusData.players.length) { %>
      <div class="table-shell">
        <table class="data-table">
          <thead>
            <tr>
              <th>Player</th>
              <th>ID</th>
              <th>Ping</th>
            </tr>
          </thead>
          <tbody>
            <% statusData.players.slice(0, 20).forEach((player) => { %>
              <tr>
                <td><%= player.name || 'Sem nome' %></td>
                <td><%= player.id ?? '-' %></td>
                <td><%= player.ping ?? '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <article class="empty-state">
        <h3>Nenhum player listado</h3>
        <p><%= statusData.error || 'Sem resposta do endpoint de players no momento.' %></p>
      </article>
    <% } %>
  </div>
</section>

<%- include('partials/site-footer') %>
