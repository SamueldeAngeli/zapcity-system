<%- include('partials/head', { pageTitle, bodyClass: 'admin-body' }) %>

<main class="login-page">
  <section class="login-card">
    <div class="login-copy">
      <span class="eyebrow">Área restrita</span>
      <h1>Zap City Admin</h1>
      <p>Painel interno para allowlist, loja, kills e consultas de histórico.</p>
    </div>

    <% if (flash) { %>
      <div class="flash flash-<%= flash.type || 'error' %>">
        <strong><%= flash.title %></strong>
        <p><%= flash.message %></p>
      </div>
    <% } %>

    <form class="stack-form" action="/admin/login" method="post">
      <label>
        <span>Usuário</span>
        <input type="text" name="username" required>
      </label>
      <label>
        <span>Senha</span>
        <input type="password" name="password" required>
      </label>
      <button class="button button-block" type="submit">Entrar</button>
    </form>
  </section>
</main>

</body>
</html>
