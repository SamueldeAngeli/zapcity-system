<header class="admin-header">
  <div class="shell admin-header-shell">
    <div class="brand admin-brand">
      <span class="brand-mark">ZC</span>
      <span class="brand-copy">
        <strong><%= app.city.shortName %> Admin</strong>
        <small>Painel interno da staff</small>
      </span>
    </div>

    <nav class="admin-nav">
      <a href="/admin" class="<%= currentPath === '/admin' ? 'is-active' : '' %>">Resumo</a>
      <a href="/admin/players" class="<%= currentPath.startsWith('/admin/players') ? 'is-active' : '' %>">Players</a>
      <a href="/admin/logs" class="<%= currentPath.startsWith('/admin/logs') ? 'is-active' : '' %>">Logs</a>
      <a href="/admin/kills" class="<%= currentPath.startsWith('/admin/kills') ? 'is-active' : '' %>">Kills</a>
      <a href="/admin/pedidos" class="<%= currentPath.startsWith('/admin/pedidos') ? 'is-active' : '' %>">Pedidos</a>
      <a href="/admin/allowlist" class="<%= currentPath.startsWith('/admin/allowlist') ? 'is-active' : '' %>">Allowlist</a>
    </nav>

    <form action="/admin/logout" method="post">
      <button class="button button-ghost" type="submit">Sair</button>
    </form>
  </div>
</header>
